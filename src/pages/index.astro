---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications'))
  .filter(p => p.data.featured && !p.data.draft)
  .sort((a,b) => b.data.year - a.data.year);
---

<h1>Mason J. Gray</h1>

<p>
  Materials scientist working at the intersection of condensed matter physics,
  topological materials, and experimental infrastructure for research.
</p>

<section>
  <h2>Current Interests</h2>
  <ul>
    <li>Topological materials in devices</li>
    <li>Condensed matter phenomena</li>
    <li>Open scientific tooling and research infrastructure</li>
  </ul>
</section>

<section>
  <h2>Selected Publications</h2>

  {publications.length === 0 ? (
    <p>See the <a href="/publications">publications page</a> for a full list.</p>
  ) : (
    <ul>
      {publications.map(pub => (
        <li>
          <strong>{pub.data.title}</strong><br />
          {pub.data.authors}<br />
          <em>
            {pub.data.venue}
            {pub.data.venue && ', '}
            {pub.data.year}
          </em>
        </li>
      ))}
    </ul>
  )}
</section>

<section>
  <h2>Links</h2>
  <ul>
    <li><a href="/cv">Curriculum Vitae</a></li>
    <li><a href="/publications">Publications</a></li>
    <li><a href="/projects">Projects</a></li>
    <li><a href="https://chat.masonjgray.com">Matrix Chat</a></li>
  </ul>
</section>
