---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications'))
  .filter(p => p.data.featured && !p.data.draft)
  .sort((a,b) => b.data.year - a.data.year);
---

<style>
  .hero { margin-bottom: 3em; }
  .hero h1 { font-size: 3.052em; margin-bottom: 0.15em; }
  .subtitle {
    color: var(--green);
    font-size: 1.1em;
    margin-top: 0;
  }
  .blurb {
    color: rgb(var(--gray));
    max-width: 540px;
  }
  section { margin-bottom: 2.5em; }
  h2 { font-size: 1.25em; margin-bottom: 0.75em; }
  .pub-list { list-style: none; padding: 0; }
  .pub-list li {
    margin-bottom: 1em;
    padding: 1em;
    background: var(--bg-card);
    border-radius: 6px;
    border: 1px solid rgba(var(--gray-light), 50%);
  }
  .pub-list li strong { color: rgb(var(--gray-dark)); }
  .pub-list .authors {
    color: rgb(var(--gray));
    font-size: 0.9em;
  }
  .pub-list .venue { color: var(--accent); font-size: 0.9em; }
</style>

<section class="hero">
  <h1>Mason J. Gray</h1>
  <p class="subtitle">
    Condensed matter · quantum infrastructure · home lab
  </p>

  <p class="blurb">
    Physicist turned quantum infrastructure manager. I build things at the
    atomic scale at work and at the garage scale at home.
  </p>
</section>

<section>
  <h2>Selected Publications</h2>

  {publications.length === 0 ? (
    <p>No featured publications yet.</p>
  ) : (
    <ul class="pub-list">
      {publications.map(pub => (
        <li>
          <strong>{pub.data.title}</strong><br />
          <span class="authors">{pub.data.authors}</span><br />
          <em>{pub.data.venue}</em>, {pub.data.year}
        </li>
      ))}
    </ul>
  )}
</section>

<section>
  <h2>Current Interests</h2>
  <ul>
    <li>Topological materials in devices</li>
    <li>Condensed matter phenomena</li>
    <li>Open scientific tooling and research infrastructure</li>
  </ul>
</section>

<section>
  <h2>Links</h2>
  <ul>
    <li><a href="/cv">Curriculum Vitae</a></li>
    <li><a href="/publications">Publications</a></li>
    <li><a href="/projects">Projects</a></li>
    <li><a href="https://chat.masonjgray.com">Matrix Chat</a></li>
  </ul>
</section>
